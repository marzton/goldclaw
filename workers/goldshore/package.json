{
  "name": "goldshore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "dev:remote": "wrangler dev --env remote --port 8787",
    "dev:staging": "wrangler dev --env staging --port 8787",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "deploy:dry": "wrangler deploy --env staging --dry-run",
    "types": "wrangler types --include-runtime false",
    "types:runtime": "wrangler types --include-runtime true",
    "check": "tsc --noEmit",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "kv:create:staging": "wrangler kv namespace create GOLDSHORE_KV --env staging",
    "kv:create:production": "wrangler kv namespace create GOLDSHORE_KV --env production",
    "kv:list": "wrangler kv namespace list",
    "tail:staging": "wrangler tail goldshore-staging",
    "tail:production": "wrangler tail goldshore-production"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260722.1",
    "typescript": "5.8.3",
    "wrangler": "4.113.0"
  }
}
